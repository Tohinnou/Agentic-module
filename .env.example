# Provider LLM
# Valeurs : mock | openrouter | ollama
LLM_PROVIDER=mock

# OpenRouter (si LLM_PROVIDER=openrouter)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-haiku-4-5

# Ollama (si LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# Base de donnees
DATABASE_URL=sqlite:///./data/sandbox.db

# Vibe Trajectory (logs post-hoc, voir CLAUDE.md §4 regle 7)
TRAJECTORY_DIR=./trajectories
TRAJECTORY_ENABLED=true

# Policy Server (voir CLAUDE.md §4 regle 4)
POLICY_CONFIG_PATH=./meta/agent_security_policy.yaml
POLICY_SEMANTIC_ENABLED=false
